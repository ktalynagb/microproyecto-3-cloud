# Copia este archivo como .env y rellena los valores reales
# cp .env.example .env

# ============================================================
# API FastAPI
# ============================================================
PCB_API_KEY=changeme-secret-key

# ============================================================
# Azure ML
# ============================================================
BATCH_ENDPOINT_URL=https://pcb-batch-inference.centralus.inference.ml.azure.com/jobs
AZURE_ML_TOKEN=

# ============================================================
# Azure Blob Storage
# ============================================================
STORAGE_ACCOUNT=pcbmlworstorage428505ef7
STORAGE_KEY=
# Alternativa: connection string completo
AZURE_STORAGE_CONNECTION_STRING=

# Contenedores
PREDICTIONS_CONTAINER=azureml-blobstore-fa3e2152-1a09-4e81-acb4-3f701118ca5e
INPUT_CONTAINER=pcb-inference-input

# ============================================================
# Polling
# ============================================================
POLL_INTERVAL_S=10
MAX_POLL_ATTEMPTS=36

# ============================================================
# CORS (separados por coma)
# ============================================================
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501,https://*.streamlit.app

# ============================================================
# Frontend Streamlit
# ============================================================
API_BASE_URL=http://localhost:8000

# ============================================================
# Azure Container Instances deployment
# ============================================================
RESOURCE_GROUP=pcb-ml-rg
LOCATION=centralus
ACR_NAME=pcbdefectacr
DNS_LABEL=pcb-defect-api

# ============================================================
# Azure ML Real-time Endpoint (opcional)
# ============================================================
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=pcb-ml-rg
AZURE_ML_WORKSPACE=pcb-ml-workspace
RT_ENDPOINT_NAME=pcb-realtime
RT_DEPLOYMENT_NAME=pcb-yolov8n-rt
MODEL_NAME=pcb-yolov8n
MODEL_VERSION=1
RT_COMPUTE_SKU=Standard_DS3_v2
RT_MIN_REPLICAS=1
RT_MAX_REPLICAS=3
