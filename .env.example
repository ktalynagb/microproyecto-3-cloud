# ============================================================
# .env.example - Variables de entorno del proyecto PCB
# ============================================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitees el .env real (está en .gitignore).
# Ver README.md sección 8 para instrucciones detalladas.
# ============================================================

# ------------------------------------------------------------
# Roboflow API (REQUERIDO para el pipeline de entrenamiento)
# Obtener en: https://app.roboflow.com/settings/account
# ------------------------------------------------------------
ROBOFLOW_API_KEY=

# ------------------------------------------------------------
# Azure ML - Configuración del Workspace
# (opcional cuando se usa az login; requerido para CI/CD)
# ------------------------------------------------------------
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=pcb-ml-rg
AZURE_WORKSPACE_NAME=pcb-ml-workspace

# ------------------------------------------------------------
# Azure Blob Storage - Exportación de resultados
# ------------------------------------------------------------
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_CONTAINER_NAME=pcb-results

# ------------------------------------------------------------
# Pipeline de Batch Inference
# ------------------------------------------------------------
BATCH_ENDPOINT_NAME=pcb-batch-inference
CONFIDENCE_THRESHOLD=0.25
PCB_IOU_THRESHOLD=0.45
PCB_INFERENCE_TIMEOUT=30

# ------------------------------------------------------------
# Backend FastAPI (servidor de inferencia local)
# ------------------------------------------------------------
API_HOST=localhost
API_PORT=8000
API_TIMEOUT=60
LOG_LEVEL=INFO

# ------------------------------------------------------------
# Modelo YOLOv8 (Hugging Face - fallback)
# ------------------------------------------------------------
HF_MODEL_ID=keremberke/yolov8n-pcb-defect-segmentation
