# ============================================================
# .env.example – Variables de entorno para el backend FastAPI
# ============================================================
# Copia este archivo como .env en deployment/azure/ y rellena
# los valores reales. NUNCA commitees el .env real.
# ============================================================

# ------------------------------------------------------------
# Backend API
# ------------------------------------------------------------
# Clave secreta para autenticar clientes del backend (header X-API-Key)
BACKEND_API_KEY=change-me-in-production

# Puerto del servidor FastAPI (default: 8080)
API_PORT=8080

# Nivel de logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Origins adicionales permitidos por CORS (separados por coma)
# Ejemplo: https://my-app.azurecontainerapps.io
CORS_EXTRA_ORIGINS=

# ------------------------------------------------------------
# Azure ML Workspace (requerido para el SDK de Azure ML)
# ------------------------------------------------------------
AZURE_SUBSCRIPTION_ID=<tu-subscription-id>
AZURE_RESOURCE_GROUP=pcb-ml-rg
AZURE_WORKSPACE_NAME=pcb-ml-workspace

# Nombre del Batch Endpoint y su deployment
AZURE_ML_ENDPOINT_NAME=pcb-batch-inference
AZURE_ML_DEPLOYMENT=pcb-yolov8n-deployment

# ------------------------------------------------------------
# Azure Blob Storage
# ------------------------------------------------------------
AZURE_STORAGE_ACCOUNT=pcbmlworstorage428505ef7
AZURE_STORAGE_KEY=<tu-storage-key>

# Container de entrada (donde se suben las imágenes para el batch)
# Debe coincidir con el workspaceblobstore del workspace de Azure ML
AZURE_INPUT_CONTAINER=azureml-blobstore-fa3e2152-1a09-4e81-acb4-3f701118ca5e

# Container de salida (donde quedan los resultados anotados, si aplica)
AZURE_OUTPUT_CONTAINER=pcb-results

# TTL de las SAS URLs en horas (default: 24)
AZURE_SAS_TTL_HOURS=24

# ------------------------------------------------------------
# Azure Container Registry (para deploy-aci.ps1)
# ------------------------------------------------------------
ACR_NAME=pcbmlacr
ACI_BACKEND_NAME=pcb-backend-aci
ACI_FRONTEND_NAME=pcb-frontend-aci
AZURE_LOCATION=centralus

# ------------------------------------------------------------
# Frontend Streamlit
# ------------------------------------------------------------
# URL del backend desplegado (para que el frontend se conecte)
# En docker-compose, el nombre del servicio se usa como host: http://pcb-backend:8080
# En ACI, usar la FQDN del backend
AZURE_BACKEND_URL=http://localhost:8080
